# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./events.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/htqa_events

# Redis (used when USE_REDIS=true)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# API Key (service-to-service fallback)
API_KEY=dev-api-key-change-me

# Rate Limiting
RATE_LIMIT=100/minute

# Logging
LOG_LEVEL=INFO

# Notifications
NOTIFICATION_EMAIL=ops@company.com
